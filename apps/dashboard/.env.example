# Postgres for the dashboard's own auth tables (users/accounts, "auth" schema).
# Can be the same instance as the Go API's DATABASE_URL.
DATABASE_URL=postgres://featherflags:featherflags@localhost:5433/featherflags?sslmode=disable

# Generate with: npx auth secret   (or: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Internal-only address of the Go API (ClusterIP service DNS in production,
# e.g. http://featherflags-api.internal.svc.cluster.local). Never exposed
# to the browser — only src/app/api/backend reads this.
INTERNAL_API_URL=http://localhost:8080
# Same value as the Go API's ADMIN_TOKEN.
INTERNAL_API_TOKEN=

# Optional: generic OIDC / company SSO. Leave unset to run credentials-only.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Set to "true" only when the OIDC_* vars above are configured, to show the
# "Sign in with SSO" button on the login page.
NEXT_PUBLIC_SSO_ENABLED=false
