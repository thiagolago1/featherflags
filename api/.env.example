# Postgres connection string
DATABASE_URL=postgres://featherflags:featherflags@localhost:5433/featherflags?sslmode=disable
# Optional Redis cache for rule sets — omit to serve straight from Postgres
REDIS_URL=redis://localhost:6380
# Bearer token for /admin routes. Must be a long random value (>=32 chars) —
# the server refuses to boot with the default/empty value or anything shorter.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=change-me-admin-token
# CORS origin allowed to read admin responses cross-origin (the dashboard
# BFF's origin). Leave empty when the API is network-isolated and only ever
# called server-to-server (recommended in production).
ALLOWED_ORIGIN=
PORT=8080
